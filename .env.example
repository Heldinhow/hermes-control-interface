# Hermes Control Interface runtime configuration
# Copy this file to .env and fill in real values.

# Required
HERMES_CONTROL_PASSWORD=change-me
HERMES_CONTROL_SECRET=change-me-too

# Optional
PORT=10272
HERMES_HOME=~/.hermes
HERMES_PROJECTS_ROOT=~/projects

# Optional explorer override.
# Accepts either:
# - JSON array of strings/objects
# - comma-separated list of paths
# Examples:
# HERMES_CONTROL_ROOTS=[{"key":"projects","label":"~/projects","root":"~/projects"},{"key":"hermes","label":"~/.hermes","root":"~/.hermes"}]
# HERMES_CONTROL_ROOTS=~/projects,~/.hermes
